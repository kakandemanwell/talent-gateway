# ============================================================
# EPRC Jobs Portal — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================
#
# DEPLOYMENT MODES
# ────────────────
# A) Docker self-hosted (feat/docker-self-hosted)
#    Storage : STORAGE_PROVIDER=minio
#    Database: self-hosted PostgreSQL (DATABASE_URL pointing to the container)
#
# B) Cloud-portable / Vercel (feat/cloud-portable)
#    Storage : STORAGE_PROVIDER=vercel-blob  OR  s3
#    Database: Neon (DATABASE_URL from Neon dashboard)
#    Frontend: deploy talent-gateway/ to Vercel
#    API     : deploy api/ to Railway / Render / Fly.io
# ============================================================


# ── Database ────────────────────────────────────────────────
#
# Option A — Docker self-hosted (internal network)
DATABASE_URL=postgres://gateway:change_me_strong_password@postgres:5432/recruitment

# Option B — Neon (from Neon dashboard → Connection Details)
# Use the POOLED connection string for the API.
# DATABASE_URL=postgresql://neondb_owner:<password>@<pooler-host>/neondb?sslmode=require

# (Docker only — used by the postgres container itself)
POSTGRES_DB=recruitment
POSTGRES_USER=gateway
POSTGRES_PASSWORD=change_me_strong_password


# ── Storage provider ────────────────────────────────────────
#
# Choose one: minio | s3 | vercel-blob   (default: minio)
STORAGE_PROVIDER=minio

# Public base URL of the portal (needed for file proxy + presigned URL generation).
# Set to the HTTPS URL where your API is reachable from the internet.
# When set, Odoo downloads files via /functions/v1/files/* (bearer-gated).
# When unset, direct presigned URLs or CDN URLs are returned instead.
STORAGE_PUBLIC_URL=https://jobs.eprc.example.com


# ── Storage: MinIO (STORAGE_PROVIDER=minio) ─────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong_password
# MINIO_BUCKET=application-files   # default


# ── Storage: S3-compatible (STORAGE_PROVIDER=s3) ────────────
# Works with AWS S3, Cloudflare R2, Backblaze B2, Tigris, Wasabi, etc.
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_BUCKET=application-files
# S3_ENDPOINT=                # leave blank for AWS S3; required for R2/B2/etc.
# S3_FORCE_PATH_STYLE=false   # set true only for older S3-compatible services


# ── Storage: Vercel Blob (STORAGE_PROVIDER=vercel-blob) ─────
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
#
# Optional — only needed when statObject/getObject are called with a legacy
# relative path (i.e. data that was originally stored via MinIO/S3).
# Set to your Vercel Blob store base URL, e.g.:
#   https://<storeId>.public.blob.vercel-storage.com
# BLOB_STORE_BASE_URL=


# ── API service ─────────────────────────────────────────────
# Shared secret between Odoo and the gateway API (≥ 32 random chars).
# Generate: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
ODOO_API_KEY=change_me_with_long_random_secret_min_32_chars

# Allowed CORS origin for the public API (your production domain).
ALLOWED_ORIGIN=https://jobs.eprc.example.com


# ── Frontend (Vite build-time) ──────────────────────────────
# Public base URL of the API service, as seen by the browser.
# For Docker: http://<YOUR_SERVER_IP>/api
# For cloud : https://<your-api-host>/api
VITE_API_URL=https://jobs-api.eprc.example.com/api


# ── TLS / Let's Encrypt (Docker only) ───────────────────────
# Leave blank to use the auto-generated self-signed certificate.
# Set both once DNS points at this server.
CERTBOT_DOMAIN=
CERTBOT_EMAIL=
