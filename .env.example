# ============================================================
# EPRC Jobs Portal — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=recruitment
POSTGRES_USER=gateway
POSTGRES_PASSWORD=change_me_strong_password

# Connection string used by the API service (internal Docker network)
DATABASE_URL=postgres://gateway:change_me_strong_password@postgres:5432/recruitment

# ── MinIO ───────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong_password

# ── API service ─────────────────────────────────────────────
# Shared secret between Odoo and the gateway API.
# Use a random string of at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
# Must match the value configured in the Odoo module.
ODOO_API_KEY=change_me_with_long_random_secret_min_32_chars

# Allowed CORS origin for the public API (your production domain).
ALLOWED_ORIGIN=https://jobs.eprc.example.com

# ── Frontend (Vite build-time) ──────────────────────────────
# Public base URL of the API service, as seen by the browser.
VITE_API_URL=https://jobs.eprc.example.com/api

# ── TLS / Let's Encrypt ──────────────────────────────────────
# Leave blank for local dev — a self-signed certificate is generated automatically.
# Set both in production to get a trusted Let's Encrypt certificate on first start.
CERTBOT_DOMAIN=jobs.eprc.example.com
CERTBOT_EMAIL=admin@eprc.example.com
