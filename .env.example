# Supabase Configuration
# These are the only client-side env vars needed.
# Use the ANON (public) key — RLS policies enforce access control.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_API_TOKEN=your-supabase-anon-key

# ─── Edge Function Secrets (set via Supabase Dashboard → Settings → Edge Functions → Secrets) ───
# NEVER put these in .env or commit them. They are listed here for documentation only.
#
# ODOO_API_KEY=<minimum 32-char random string, shared only with the Odoo team>
#              Generate with: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase into all Edge Functions.
# ALLOWED_ORIGIN=https://odoo.your-domain.com  (restrict CORS to the Odoo server hostname)
