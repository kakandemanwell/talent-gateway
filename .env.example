# ============================================================
# EPRC Jobs Portal — Environment Variables (Vercel deployment)
# Copy this file to .env.local for local dev (Vite + vercel dev).
# Set each variable in the Vercel dashboard for preview/production.
# NEVER commit .env.local to version control.
# ============================================================

# ── Neon PostgreSQL ─────────────────────────────────────────
# Use the *pooler* connection string (host ends with -pooler.neon.tech)
# so that short-lived serverless function connections don't exhaust
# the connection limit.
# Found in: Neon console → your project → Connection Details → Pooled connection
DATABASE_URL=postgres://user:password@ep-xxx-pooler.neon.tech/neondb?sslmode=require

# ── Vercel Blob ─────────────────────────────────────────────
# Created automatically when you link a Blob store to your Vercel project.
# Copy from: Vercel dashboard → Storage → your blob store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# ── Odoo API ────────────────────────────────────────────────
# Shared secret between Odoo and the gateway API.
# Use a random string of at least 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
# Must match the value configured in the Odoo module.
ODOO_API_KEY=change_me_with_long_random_secret_min_32_chars

# ── CORS ────────────────────────────────────────────────────
# Allowed origin for the public portal API.
# In production this is your Vercel deployment URL, e.g.:
#   https://talent-gateway.vercel.app  or  https://jobs.eprc.example.com
# For local dev you can set this to http://localhost:5173
ALLOWED_ORIGIN=https://your-project.vercel.app

# ── Frontend (Vite build-time) ──────────────────────────────
# Leave blank on Vercel — the frontend and serverless functions share
# the same origin, so /api resolves automatically.
# Only set this when running the frontend against a remote API during local dev.
# VITE_API_URL=http://localhost:3000/api
